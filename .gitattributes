* text=auto

# ROS/Linux deployment scripts must keep LF line endings. CRLF changes the
# shebang to /usr/bin/env "bash\r" and makes scripts fail at startup.
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.xacro text eol=lf
*.urdf text eol=lf
*.json text eol=lf
*.md text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
